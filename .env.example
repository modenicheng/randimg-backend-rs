# Database URL (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite://data/randimg.db?mode=rune
# DATABASE_URL=postgres://user:password@localhost/randimg

# JWT secret key (REQUIRED - must be changed)
SECRET_KEY=change-me-to-a-random-secret

# JWT token expiration in minutes
JWT_EXPIRE_MINUTES=60

# CDN base URL for image serving
CDN_BASE_URL=https://cdn.modenc.top/

# Local image storage directory
IMAGE_DIR=./images

# Server listen address
SERVER_ADDR=0.0.0.0:8000

# Pixiv API refresh token (for crawler)
PIXIV_REFRESH_TOKEN=

# Pixiv API proxy (optional)
PIXIV_PROXY=http://127.0.0.1:1080

# Logging level (RUST_LOG format: target1=level,target2=level)
# Levels: trace, debug, info, warn, error
# Examples:
#   randimg_backend_rs=info                    (default - app info only)
#   randimg_backend_rs=debug,tower_http=info   (app debug + HTTP info)
#   randimg_backend_rs=trace                   (very verbose)
RUST_LOG=randimg_backend_rs=info,tower_http=info

# Log output directory (default: ./logs). Logs rotate daily.
# LOG_DIR=./logs

# JSON log format (set to true for production / log aggregation tools)
# LOG_JSON=false
